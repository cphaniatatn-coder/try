<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mandarin Learning Game - Lesson 1</title>
    <style>
        :root {
            --primary: #2c3e50;
            --secondary: #e67e22;
            --bg: #f4f7f6;
            --white: #ffffff;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg);
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        #game-container {
            width: 850px;
            height: 500px;
            background: var(--white);
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            position: relative;
            overflow: hidden;
            border: 2px solid #ddd;
        }

        /* Progress Bar */
        .progress-container {
            position: absolute;
            top: 20px;
            left: 50px;
            width: 200px;
            height: 15px;
            background: #eee;
            border-radius: 10px;
        }
        #progress-bar {
            width: 0%;
            height: 100%;
            background: #3498db;
            border-radius: 10px;
            transition: 0.5s;
        }

        /* Screen Management */
        .screen {
            display: none;
            padding: 40px;
            height: 100%;
            box-sizing: border-box;
        }
        .active { display: block; }

        h1 { color: var(--primary); margin-top: 40px; }
        
        .btn {
            background: var(--secondary);
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
            font-weight: bold;
            transition: 0.3s;
        }
        .btn:hover { background: #d35400; transform: translateY(-2px); }

        /* Vocabulary Screen */
        .family-grid {
            display: flex;
            gap: 20px;
            margin-top: 20px;
        }
        .member-card {
            border: 2px solid #eee;
            padding: 15px;
            border-radius: 10px;
            text-align: center;
            cursor: pointer;
            flex: 1;
        }
        .member-card:hover { border-color: var(--secondary); background: #fffaf5; }

        /* Quiz Styles */
        .quiz-options {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin-top: 30px;
        }
        .option {
            background: #f9f9f9;
            border: 2px solid #ddd;
            padding: 20px;
            border-radius: 10px;
            cursor: pointer;
            text-align: center;
        }
        .option:hover { border-color: #3498db; }

        /* Result Circle */
        .circle-score {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            border: 10px solid var(--secondary);
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 40px;
            font-weight: bold;
            margin: 20px auto;
        }
    </style>
</head>
<body>

<div id="game-container">
    <div class="progress-container"><div id="progress-bar"></div></div>

    <div id="screen-intro" class="screen active">
        <h1>第一課：我的家庭 <br><small>(Lesson 1: My Family)</small></h1>
        <ul style="line-height: 1.8;">
            <li>1. Identify and name family members.</li>
            <li>2. Use '有' (have) to talk about family size.</li>
            <li>3. Understand basic family relations.</li>
        </ul>
        <button class="btn" onclick="nextScreen('screen-vocab', 25)">Start Learning →</button>
    </div>

    <div id="screen-vocab" class="screen">
        <h2>生詞 Vocabulary</h2>
        <p>Klik anggota keluarga untuk belajar:</p>
        <div class="family-grid">
            <div class="member-card" onclick="alert('爺爺 (Yéye) - Kakek')">👴<br>Grandfather</div>
            <div class="member-card" onclick="alert('奶奶 (Nǎinai) - Nenek')">👵<br>Grandmother</div>
            <div class="member-card" onclick="alert('爸爸 (Bàba) - Ayah')">👨<br>Father</div>
            <div class="member-card" onclick="alert('媽媽 (Māma) - Ibu')">👩<br>Mother</div>
        </div>
        <br><br>
        <button class="btn" onclick="nextScreen('screen-grammar', 50)">Next: Grammar →</button>
    </div>

    <div id="screen-grammar" class="screen">
        <h2>語法 Grammar</h2>
        <div style="background: #eef; padding: 20px; border-radius: 10px;">
            <h3>Pola Kalimat: 有 (Have)</h3>
            <p><strong>我家有五個人。</strong><br>(Wǒ jiā yǒu wǔ gè rén)<br>Keluarga saya punya 5 orang.</p>
        </div>
        <br>
        <button class="btn" onclick="nextScreen('screen-exercise', 75)">Take Exercise →</button>
    </div>

    <div id="screen-exercise" class="screen">
        <h2>練習 Exercise (TOCFL Prep)</h2>
        <p>Pilih gambar yang sesuai dengan kalimat: <strong>"這是我爺爺"</strong></p>
        <div class="quiz-options">
            <div class="option" onclick="wrong()">👧<br>A. Adik Perempuan</div>
            <div class="option" onclick="correct()">👴<br>B. Kakek (Yéye)</div>
            <div class="option" onclick="wrong()">👦<br>C. Kakak Laki-laki</div>
        </div>
    </div>

    <div id="screen-result" class="screen">
        <h1 style="text-align:center;">恭喜 Congratulate!</h1>
        <div class="circle-score" id="final-score">95%</div>
        <p style="text-align:center;">Total Score: 95/100</p>
        <div style="text-align:center;">
            <button class="btn" onclick="location.reload()">Ulangi Belajar</button>
        </div>
    </div>
</div>

<script>
    function nextScreen(screenId, progress) {
        // Sembunyikan semua screen
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
        // Tampilkan screen tujuan
        document.getElementById(screenId).classList.add('active');
        // Update progress bar
        document.getElementById('progress-bar').style.width = progress + "%";
    }

    function correct() {
        alert("Benar! (Correct)");
        nextScreen('screen-result', 100);
    }

    function wrong() {
        alert("Coba lagi! Ingat: 爺爺 (Yéye) adalah Kakek.");
    }
</script>

</body>
</html>
